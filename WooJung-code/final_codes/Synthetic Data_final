al 7 columns):\n"," #   Column            Non-Null Count  Dtype         \n","---  ------            --------------  -----         \n"," 0   ID                33542 non-null  object        \n"," 1   timestamp         33542 non-null  datetime64[ns]\n"," 2   glucose           33542 non-null  float64       \n"," 3   glucose_category  33542 non-null  object        \n"," 4   normal_range      33542 non-null  bool          \n"," 5   gap_min           33255 non-null  float64       \n"," 6   train_test        33542 non-null  object        \n","dtypes: bool(1), datetime64[ns](1), float64(2), object(3)\n","memory usage: 1.6+ MB\n"]},{"output_type":"display_data","data":{"text/plain":["None"]},"metadata":{}},{"output_type":"display_data","data":{"text/plain":["count    33542.000000\n","mean       308.029575\n","std        131.255848\n","min         40.000000\n","25%        198.000000\n","50%        310.000000\n","75%        421.000000\n","max        500.000000\n","Name: glucose, dtype: float64"],"text/html":["<div>\n","<style scoped>\n","    .dataframe tbody tr th:only-of-type {\n","        vertical-align: middle;\n","    }\n","\n","    .dataframe tbody tr th {\n","        vertical-align: top;\n","    }\n","\n","    .dataframe thead th {\n","        text-align: right;\n","    }\n","</style>\n","<table border=\"1\" class=\"dataframe\">\n","  <thead>\n","    <tr style=\"text-align: right;\">\n","      <th></th>\n","      <th>glucose</th>\n","    </tr>\n","  </thead>\n","  <tbody>\n","    <tr>\n","      <th>count</th>\n","      <td>33542.000000</td>\n","    </tr>\n","    <tr>\n","      <th>mean</th>\n","      <td>308.029575</td>\n","    </tr>\n","    <tr>\n","      <th>std</th>\n","      <td>131.255848</td>\n","    </tr>\n","    <tr>\n","      <th>min</th>\n","      <td>40.000000</td>\n","    </tr>\n","    <tr>\n","      <th>25%</th>\n","      <td>198.000000</td>\n","    </tr>\n","    <tr>\n","      <th>50%</th>\n","      <td>310.000000</td>\n","    </tr>\n","    <tr>\n","      <th>75%</th>\n","      <td>421.000000</td>\n","    </tr>\n","    <tr>\n","      <th>max</th>\n","      <td>500.000000</td>\n","    </tr>\n","  </tbody>\n","</table>\n","</div><br><label><b>dtype:</b> float64</label>"]},"metadata":{}}]},{"cell_type":"markdown","source":["# 🔆 Minute-Level Canine Synthetic Data\n","\n","We start with linear interpolation because it is the simplest, most transparent baseline for filling irregular gaps. It makes minimal assumptions: glucose changes smoothly between two observed readings, and the estimate is determined by the endpoints.\n","\n","\n","## Methodology:\n","\n","* **Synthetic Minute-Level Grid**: Creates a 1-minute timeline between the first and last recorded measurement for each dog(subset) ID.\n","* **Linear Interpolation:** Fills missing minutes by assuming a straight-line trend between any two consecutive known glucose readings.\n","* **Keep Observed Value:** Ensures all real, original measurements are kept at their exact minute-mark.\n","* **Inside-Only Synthesis:** Restricts interpolation to the gaps between existing data points, avoiding any guesswork before or after a dog's monitoring period."],"metadata":{"id":"fbmorFtnjTWs"}},{"cell_type":"code","source":["def build_minute_level_series_keep_observed(\n","    df,\n","    id_col=\"ID\",\n","    ts_col=\"timestamp\",\n","    g_col=\"glucose\",\n","):\n","    \"\"\"\n","    Performs linear interpolation to fill missing glucose levels for every minute\n","    between consecutive observed values for each dog(subset).\n","    Real observed values are preserved in the resulting 1-minute grid.\n","    \"\"\"\n","    d = df.copy()\n","\n","    # Prepare for merging into a continuous timeline\n","    d = d.rename(columns={g_col: \"observed_glucose\"})\n","    d[\"is_observed\" ] = True\n","\n","    out = []\n","    # Process each dog individually to ensure no overlap in timelines\n","    for fid, sub in d.groupby(id_col):\n","        # Set time as index\n","        sub = sub.set_index(ts_col)\n","\n","        # Create a full range of 1-minute intervals between the dog's first and last available readings\n","        full_index = pd.date_range(sub.index.min(), sub.index.max(), freq=\"1min\")\n","        sub_full = sub.reindex(full_index)\n","\n","        # Restore the dog ID and set observed flag to False for synthetic minutes\n","        sub_full[id_col] = fid\n","        # adding astype boolean to avoid future trouble\n","        sub_full[\"is_observed\"] = sub_full[\"is_observed\"].notna()\n","\n","        # Linear interpolation between observed points (fills inside gaps only)\n","        sub_full[\"glucose_1min\"] = sub_full[\"observed_glucose\"].interpolate(\n","            method=\"time\",\n","            limit_area=\"inside\"\n","        )\n","\n","        sub_full = sub_full.reset_index().rename(columns={\"index\": \"timestamp\"})\n","        out.append(sub_full)\n","\n","    # Combine all dogs back into a single dataframe\n","    minute_df = pd.concat(out, ignore_index=True)\n","\n","    return minute_df[[id_col, \"timestamp\", \"observed_glucose\", \"glucose_1min\", \"is_observed\"]]\n"],"metadata":{"id":"QagbtGuMJB1K","executionInfo":{"status":"ok","timestamp":1774828742598,"user_tz":240,"elapsed":19,"user":{"displayName":"WooJung Kim","userId":"15923704063029269921"}},"collapsed":true},"execution_count":8,"outputs":[]},{"cell_type":"code","source":["# generate synthetic dataset\n","df_syn = build_minute_level_series_keep_observed(all_df)"],"metadata":{"id":"bsqz200867Ta","executionInfo":{"status":"ok","timestamp":1774828745738,"user_tz":240,"elapsed":1370,"user":{"displayName":"WooJung Kim","userId":"15923704063029269921"}}},"execution_count":9,"outputs":[]},{"cell_type":"code","source":["df_syn.head()"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":206},"id":"UUBIG2c09CRQ","executionInfo":{"status":"ok","timestamp":1774828746343,"user_tz":240,"elapsed":17,"user":{"displayName":"WooJung Kim","userId":"1592370