":"markdown","source":["###✅ **Summary**\n","\n","* Does it look like real CGM data?\n","  * How big are minute-to-minute jumps?\n","  * What's the short-term trend over ~5mins: ROC5\n","  * Hyper/Hypo Threshold crossings not inflated\n"],"metadata":{"id":"btn89UODArP-"}},{"cell_type":"code","source":["# Set the valuse and thresholds\n","\n","ID_COL = \"ID\"\n","TIME_COL = \"timestamp\"\n","HYPO_TH = 65\n","HYPER_TH = 250\n","\n","BASE_COL = \"glucose_1min\"          # linear interpolation baseline\n","AR1_COL  = \"glucose_1min_noisy\"    # AR(1)+taper output\n","BB_COL   = \"glucose_1min_bb\"       # Brownian Bridge output\n","\n","\n","# Calculate Δ1 / ROC5\n","def d1_and_roc5(df, value_col):\n","    \"\"\"Compute Δ1(minute-to-minute change) and ROC5(ROC over 5mins) across all dogs.\"\"\"\n","    d = df[[ID_COL, TIME_COL, value_col]].copy()\n","\n","    d1_list, roc5_list = [], []\n","    for _, g in d.groupby(ID_COL, sort=False):\n","        x = g[value_col].astype(float)\n","        d1_list.append(x.diff(1).dropna())\n","        roc5_list.append((x.diff(5) / 5.0).dropna())\n","\n","    return pd.concat(d1_list, ignore_index=True), pd.concat(roc5_list, ignore_index=True)\n","\n","\n","def summary_stats(x, name):\n","    \"\"\"Small summary table: n, std, p05/p50/p95.\"\"\"\n","    x = x.replace([np.inf, -np.inf], np.nan).dropna()\n","    return {\n","        \"metric\": name,\n","        \"n\": int(len(x)),\n","        \"std\": float(x.std(ddof=0)) if len(x) else np.nan,\n","        \"p05\": float(x.quantile(0.05)) if len(x) else np.nan,\n","        \"p50\": float(x.quantile(0.50)) if len(x) else np.nan,\n","        \"p95\": float(x.quantile(0.95)) if len(x) else np.nan,\n","    }"],"metadata":{"id":"7ECCOH6PCvK1","executionInfo":{"status":"ok","timestamp":1774828843921,"user_tz":240,"elapsed":2,"user":{"displayName":"WooJung Kim","userId":"15923704063029269921"}}},"execution_count":25,"outputs":[]},{"cell_type":"code","source":["# RUN: Δ1 / ROC5 summaries\n","base_d1, base_roc5 = d1_and_roc5(df_syn, BASE_COL)\n","ar1_d1,  ar1_roc5  = d1_and_roc5(minute_canine_noisy_ar1_taper, AR1_COL)\n","\n","plaus_df = pd.DataFrame([\n","    summary_stats(base_d1,  \"BASE Δ1\"),\n","    summary_stats(ar1_d1,   \"AR1  Δ1\"),\n","    summary_stats(base_roc5,\"BASE ROC5\"),\n","    summary_stats(ar1_roc5, \"AR1  ROC5\"),\n","])\n","\n","print(\"=== tΔ1 and ROC5 summary ===\")\n","print(plaus_df)"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"5egpcqmeEgma","executionInfo":{"status":"ok","timestamp":1774828845726,"user_tz":240,"elapsed":671,"user":{"displayName":"WooJung Kim","userId":"15923704063029269921"}},"outputId":"9315b80f-9f59-4b0e-dc67-5ab18a548428"},"execution_count":26,"outputs":[{"output_type":"stream","name":"stdout","text":["=== tΔ1 and ROC5 summary ===\n","      metric       n       std       p05       p50       p95\n","0    BASE Δ1  393064  1.635942 -2.266667  0.000000  2.200000\n","1    AR1  Δ1  393064  2.012507 -2.978990  0.000000  2.941087\n","2  BASE ROC5  391916  1.389129 -2.160000  0.000000  2.133333\n","3  AR1  ROC5  391916  1.464490 -2.285263  0.001904  2.255479\n"]}]},{"cell_type":"markdown","source":["Are the Hyper/Hypo Threshold crossings inflated?"],"metadata":{"id":"iWMAhOv5YMCd"}},{"cell_type":"code","source":["def threshold_crossings(\n","    df: pd.DataFrame,\n","    value_col: str,\n","    hypo_th: float = 65,\n","    hyper_th: float = 250\n",") -> dict:\n","    \"\"\"\n","    Counts the number of times glucose levels enter hypo- or hyperglycemia\n","    ranges on a minute-by-minute grid for each ID.\n","\n","    A 'hypo entry' is counted when glucose transitions from >= `hypo_th` to < `hypo_th`.\n","    A 'hyper entry' is counted when glucose transitions from <= `hyper_th` to > `hyper_th`.\n","    \"\"\"\n","    d = df[[ID_COL, TIME_COL, value_col]].copy()\n","\n","    total_hypo_enters = 0\n","    total_hyper_enters = 0\n","\n","    for _, g in d.groupby(ID_COL, sort=False):\n","        # Convert glucose values to numpy array for efficient comparison\n","        glucose_values = g[value_col].astype(float).to_numpy()\n","\n","        # Ensure there are at least two points to check for transitions\n","        if len(glucose_values) < 2:\n","            continue\n","\n","        prev_values = glucose_values[:-1]\n","        curr_values = glucose_values[1:]\n","\n","        # Count transitions into hypoglycemia\n","        # From not hypo (>= threshold) to hypo (< threshold)\n","        hypo_transitions = (prev_values >= hypo_th) & (curr_values < hypo_th)\n","        total_hypo_enters += np.sum(hypo_transitions)\n","\n","        # Count transitions into hyperglycemia\n","        # From not hyper (<= threshold) to hyper (> threshold)\n","        hyper_transitions = (prev_values <= hyper_th) & (curr_values > hyper_th)\n","        total_hyper_enters += np.sum(hyper_transitions)\n","\n","    return {\n","        \"hypo_enters\": int(total_hypo_enters),\n","        \"hyper_enters\": int(total_hyper_enters),\n","        \"total_enters\": int(total_hypo_enters + total_hyper_enters),\n","        \"hypo_ratio\": total_hypo_enters / (total_hypo_enters + total_hyper_enters),\n","        \"hyper_ratio\": total_hyper_enters / (total_hypo_enters + total_hyper_enters)\n","    }\n"],"metadata":{"id":"Fs--dnqwEsij","executionInfo":{"status":"ok","timestamp":1774828849600,"user_tz":240,"elapsed":2,"user":{"displayName":"WooJung Kim","userId":"15923704063029269921"}}},"execution_count":27,"outputs":[]},{"cell_type":"code","source":["# RUN: threshold crossings\n","\n","cross_base = threshold_crossings(df_syn, BASE_COL)\n","cross_ar1  = threshold_crossings(minute_canine_noisy_ar1_taper, AR1_COL)\n","\n","cross_df = pd.DataFrame([\n","    {\"series\": \"BASE\", **cross_base},\n","    {\"series\": \"AR1\",  **cross_ar1},\n","])\n","\n","print(\"\\n=== threshold crossings (enter hypo/hyper) ===\")\n","print(cross_df)"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"MDJ9hlXZEzs1","executionInfo":{"status":"ok","timestamp":1774828852058,"user_tz":240,"elapsed":341,"user":{"displayName":"WooJung Kim","userId":"15923704063029269921"}},"outputId":"866001db-9abd-433b-8492-c89422e3f005"},"execution_count":28,"outputs":[{"output_type":"stream","name":"stdout","text":["\n","=== threshold crossings (enter hypo/hyper) ===\n","  series  hypo_enters  hyper_enters  total_enters  hypo_ratio  hyper_ratio\n","0   BASE           79           484           563    0.140320     0.859680\n","1    AR1          121           609           730    0.165753     0.834247\n"]}]},{"cell_type":"markdown","source":["Comparing the orginal final_df, % out-of-range the synthetic data"],"metadata":{"id":"zXgpoCKEc3lm"}},{"cell_type":"code","source":["# Classifies glucose values into Hypo, Normal, or Hyper categories.\n","def classify_glucose(df, value_col, hypo_th=65, hyper_th=250):\n","\n","    conditions = [\n","        df[value_col] < hypo_th,\n","        (df[value_col] >= hypo_th) & (df[value_col] <= hyper_th),\n","        df[value_col] > hyper_th\n","    ]\n","    choices = ['Hypo', 'Normal', 'Hyper']\n","    return np.select(conditions, choices, default='Unknown')\n","\n","# Calculates counts and percentages for glucose categories.\n","def get_glucose_stats(df, value_col, df_name):\n","\n","    categories = classify_glucose(df, value_col, HYPO_TH, HYPER_TH)\n","    counts = pd.Series(categories).value_counts().to_dict()\n","    total_count = sum(counts.values())\n","\n","    stats = {'DataFrame': df_name}\n","    for cat in ['Hypo', 'Normal', 'Hyper']:\n","        count = counts.get(cat, 0)\n","        percentage = (count / total_count) * 100 if total_count > 0 else 0\n","        stats[f'{cat}'] = count\n","        stats[f'{cat}%'] = f'{percentage:.2f}%'\n","    return stats\n","\n","\n","# 4 dfs\n","dataframes_to_compare = [\n","    (all_df, 'glucose', 'Original final_df'),\n","    (df_syn, BASE_COL, 'Linear Interpolated'),\n","    (minute_canine_noisy_ar1_taper, AR1_COL, 'AR1+Taper Noisy')\n","]\n","\n","# Calculate and collect statistics for each df\n","comparison_results = []\n","for df, col, name in dataframes_to_compare:\n","    comparison_results.append(get_glucose_stats(df, col, name))\n","\n","# Display results\n","comparison_df = pd.DataFrame(comparison_results)\n","print(\"\\n=== Glucose Category Comparison ===\")\n","display(comparison_df)\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":178},"id":"WVbBL90abUhn","executionInfo":{"status":"ok","timestamp":1774828854722,"user_tz":240,"elapsed":232,"user":{"displayName":"WooJung Kim","userId":"15923704063029269921"}},"outputId":"4e07067f-1137-4971-d982-efd3e305ca32"},"execution_count":29,"outputs":[{"output_type":"stream","name":"stdout","text":["\n","=== Glucose Category Comparison ===\n"]},{"output_type":"display_data","data":{"text/plain":["             DataFrame  Hypo  Hypo%  Normal Normal%   Hyper  Hyper%\n","0    Original final_df   361  1.08%   11955  35.64%   21226  63.28%\n","1  Linear Interpolated  2612  0.66%  132523  33.69%  258216  65.65%\n","2      AR1+Taper Noisy  2597  0.66%  132392  33.66%  258362  65.68%"],"text/html":["\n","  <div id=\"df-eb078e03-3b45-4910-8fd6-76f9cf871d4e\" class=\"colab-df-container\">\n","    <div>\n","<style scoped>\n","    .dataframe tbody tr th:only-of-type {\n","        vertical-align: middle;\n","    }\n","\n","    .dataframe tbody tr th {\n","        vertical-align: top;\n","    }\n","\n","    .dataframe thead th {\n","        text-align: right;\n","    }\n","</style>\n","<table border=\"1\" class=\"dataframe\">\n","  <thead>\n","    <tr style=\"text-align: right;\">\n","      <th></th>\n","      <th>DataFrame</th>\n","      <th>Hypo</th>\n","      <th>Hypo%</th>\n","      <th>Normal</th>\n","      <th>Normal%</th>\n","      <th>Hyper</th>\n","      <th>Hyper%</th>\n","    </tr>\n","  </thead>\n","  <tbody>\n","    <tr>\n","      <th>0</th>\n","      <td>Original final_df</td>\n","  