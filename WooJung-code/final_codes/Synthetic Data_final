y(\"ID\"):\n","        observed_in_minute = sub[\"is_observed\"].sum()\n","        expected = orig_counts.get(fid, 0)\n","\n","        if observed_in_minute != expected:\n","            any_issues = True\n","            print(f\"ID {fid} mismatch: Found {observed_in_minute} observed rows, expected {expected}\")\n","\n","    if not any_issues:\n","        print(\"Check complete: All IDs have observed counts matching original unique minute timestamps.\")"],"metadata":{"id":"GSzRJ4PzNPE9","executionInfo":{"status":"ok","timestamp":1774828751221,"user_tz":240,"elapsed":5,"user":{"displayName":"WooJung Kim","userId":"15923704063029269921"}}},"execution_count":13,"outputs":[]},{"cell_type":"code","source":["sanity_check_observed_logic(df_syn, all_df)"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"gdv-qUYv9Lav","executionInfo":{"status":"ok","timestamp":1774828752040,"user_tz":240,"elapsed":114,"user":{"displayName":"WooJung Kim","userId":"15923704063029269921"}},"outputId":"83d45cb6-134f-4f23-f1d3-b7ab82980ca9"},"execution_count":14,"outputs":[{"output_type":"stream","name":"stdout","text":["=== STARTING OBSERVED LOGIC CHECK ===\n","Check complete: All IDs have observed counts matching original unique minute timestamps.\n"]}]},{"cell_type":"code","source":["# 3. Visual Sanity Check\n","def plot_sanity(minute_df, fid):\n","    sub = minute_df[minute_df[\"ID\"] == fid].copy()\n","    sub[\"timestamp\"] = pd.to_datetime(sub[\"timestamp\"])\n","\n","    plt.figure(figsize=(30, 5))\n","\n","    # 1. Plot synthetic/interpolated values as scatter\n","    synth = sub[~sub[\"is_observed\"]]\n","    plt.scatter(synth[\"timestamp\"], synth[\"glucose_1min\"],\n","                color=\"green\", marker=\"x\", label=\"Synthetic (Interpolated)\", s=10, alpha=0.5)\n","\n","    # 2. Plot observed values as line with markers\n","    obs = sub[sub[\"is_observed\"]]\n","    plt.plot(obs[\"timestamp\"], obs[\"observed_glucose\"],\n","             color=\"gray\", marker=\"o\", mfc=\"red\", mec=\"red\", linestyle=\"-\", label=\"Observed Readings\",\n","             linewidth=1, markersize=4, zorder=5)\n","\n","    # Formatting axis and titles\n","    plt.title(f\"Comparison of Observed and Linear Interpolated Glucose Levels - {fid}\")\n","    plt.ylabel(\"Glucose (mg/dL)\")\n","    plt.xlabel(\"Timestamp (MM-DD HH:MM)\")\n","\n","    # Set x-axis granularity to minutes\n","    ax = plt.gca()\n","    ax.xaxis.set_major_formatter(mdates.DateFormatter('%m-%d %H:%M'))\n","    # Use a MinuteLocator to force ticks at 30-minute intervals for better granularity\n","    ax.xaxis.set_major_locator(mdates.MinuteLocator(interval=30))\n","    plt.xticks(rotation=45)\n","\n","    plt.legend()\n","    plt.grid(True, alpha=0.3)\n","    plt.tight_layout()\n","    plt.show()\n","\n","# Usage: Plot 5 random IDs\n","all_ids = list(df_syn[\"ID\"].unique())\n","random_5_ids = random.sample(all_ids, min(5, len(all_ids)))\n","\n","for fid in random_5_ids:\n","    plot_sanity(df_syn, fid)"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":1000},"id":"c5zC4JL8P04u","executionInfo":{"status":"ok","timestamp":1774828759622,"user_tz":240,"elapsed":6976,"user":{"displayName":"WooJung Kim","userId":"15923704063029269921"}},"outputId":"1eff67f3-6b97-49b4-bb00-aed207b847c1"},"execution_count":15,"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 3000x500 with 1 Axes>"],"image/png":"\n"},"metadata":{}},{"output_type":"display_data","data":{"text/plain":["<Figure size 3000x500 with 1 Axes>"],"image/png":"\n"},"metadata":{}},{"output_type":"display_data","data":{"text/plain":["<Figure size 3000x500 with 1 Axes>"],"image/png":"\n"},"metadata":{}},{"output_type":"display_data","data":{"text/plain":["<Figure size 3000x500 with 1 Axes>"],"image/png":"\n"},"metadata":{}},{"output_type":"display_data","data":{"text/plain":["<Figure size 3000x500 with 1 Axes>"],"image/png":"\n"},"metadata":{}}]},{"cell_type":"markdown","source":["###