2.064287515991205 2.3758770937793443 10.52292319454103\n"]}]},{"cell_type":"markdown","source":["**Step 2: Apply segment-wise AR(1) + taper noise** (ONLY to synthetic minutes)\n","\n","Inside the consecutive minutes, we:\n","  * generate AR(1) noise eps[t]\n","  * compute taper weights w[t] = sin(pi * k / L)\n","  * add w[t] * eps[t] to the synthetic minutes"],"metadata":{"id":"TgBvTxd5kEAL"}},{"cell_type":"code","source":["def apply_ar1_taper_noise(\n","    minute_canine: pd.DataFrame,\n","    sigma_by_id: dict,\n","    id_col: str = \"ID\",\n","    time_col: str = \"timestamp\",\n","    interp_col: str = \"glucose_1min\",\n","    obs_col: str = \"observed_glucose\",\n","    is_obs_col: str = \"is_observed\",\n","    out_col: str = \"glucose_1min_noisy\",\n","    rho: float = 0.85,\n","    random_state: int = 42,\n",") -> pd.DataFrame:\n","    \"\"\"\n","    Adds temporally correlated (AR1) noise to synthetic segments using a sine-wave taper\n","    to ensure noise is zero at the observed endpoints.\n","    \"\"\"\n","    rng = np.random.default_rng(random_state)\n","    d = minute_canine.copy()\n","\n","    # Initialize output column with interpolated values and overwrite observed minutes with real data\n","    d[out_col] = d[interp_col].astype(float)\n","    obs_mask = d[is_obs_col].astype(bool)\n","    d.loc[obs_mask, out_col] = d.loc[obs_mask, obs_col].astype(float)\n","\n","    for gid, g in d.groupby(id_col, sort=False):\n","        y = g[out_col].to_numpy(dtype=float)\n","        obs_indices = np.where(g[is_obs_col].to_numpy(dtype=bool))[0]\n","\n","        # Calculate innovation standard deviation for the AR(1) process based on dog-specific variability\n","        sigma_eta = float(sigma_by_id.get(gid, 1.0)) * np.sqrt(1 - rho**2)\n","\n","        # Iterate through segments between consecutive real measurements\n","        for start, end in zip(obs_indices[:-1], obs_indices[1:]):\n","            gap = end - start\n","\n","            # If there is at least one synthetic minute in the gap\n","            if gap > 1:\n","                # Generate sine-wave taper weights: 0 at endpoints, peaking in the middle\n","                k = np.arange(1, gap)\n","                weights = np.sin(np.pi * k / gap)\n","\n","                # Generate AR(1) noise: each step depends on the previous step (momentum)\n","                eps = np.zeros(gap + 1)\n","                for t in range(1, gap):\n","                    eps[t] = rho * eps[t-1] + rng.normal(0, sigma_eta)\n","\n","                # Apply the tapered noise to the synthetic glucose values\n","                y[start + 1 : end] += weights * eps[1:gap]\n","\n","        # Save the modified values for this dog back to the dataframe\n","        d.loc[g.index, out_col] = y\n","\n","    return d"],"metadata":{"id":"cW3YoByge1Lp","executionInfo":{"status":"ok","timestamp":1774828826056,"user_tz":240,"elapsed":2,"user":{"displayName":"WooJung Kim","userId":"15923704063029269921"}}},"execution_count":22,"outputs":[]},{"cell_type":"code","source":["# Apply AR(1)+taper\n","minute_canine_noisy_ar1_taper = apply_ar1_taper_noise(\n","    df_syn,\n","    sigma_by_id=sigma_by_id,\n","    rho=0.85,\n","    random_state=42,\n",")\n","\n","display(minute_canine_noisy_ar1_taper.head())"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":206},"id":"k7iCkRiyb5hD","executionInfo":{"status":"ok","timestamp":1774828827969,"user_tz":240,"elapsed":1203,"user":{"displayName":"WooJung Kim","userId":"15923704063029269921"}},"outputId":"d2cf943d-d706-4e81-ccdf-f93fc42fa7dc"},"execution_count":23,"outputs":[{"output_type":"display_data","data":{"text/plain":["            ID           timestamp  observed_glucose  glucose_1min  \\\n","0  canine1-001 2025-11-01 05:51:00             375.0         375.0   \n","1  canine1-001 2025-11-01 05:52:00               NaN         375.0   \n","2  canine1-001 2025-11-01 05:53:00               NaN         375.0   \n","3  canine1-001 2025-11-01 05:54:0